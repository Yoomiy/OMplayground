# apps/web (Vite) — copy to apps/web/.env.local
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Local dev: omit — the app uses the Vite dev server proxy to :8080. Production: set your Railway URL.
# VITE_GAME_SERVER_URL=https://YOUR_GAME_HOST
# Voxel (minecraft) server — local dev default is :8081 (separate Railway service in prod).
VITE_VOXEL_SERVER_URL=http://localhost:8081

# apps/game-server — copy to apps/game-server/.env
PORT=8080
# Comma-separated; include 127.0.0.1 if you open the app that way (different origin from localhost)
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
# Must be the full URL with https:// (same project as VITE_SUPABASE_URL)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# apps/minecraft-server — copy to apps/minecraft-server/.env
# (Same shape as apps/game-server; just a different port so both can run locally.)
# PORT=8081
# CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# LIVEKIT_API_KEY=devkey
# LIVEKIT_API_SECRET=secret

{
  "name": "playground-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "dev:web": "npm run dev -w @playground/web",
    "dev:server": "npm run dev -w @playground/game-server",
    "dev:minecraft": "npm run dev -w @playground/minecraft-server",
    "lint": "npm run lint --workspaces --if-present",
    "borrow-voxel-textures": "tsx scripts/borrow-voxel-textures.ts",
    "borrow-voxel-audio": "tsx scripts/borrow-voxel-audio.ts"
  },
  "devDependencies": {
    "tsx": "^4.22.3",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "livekit-server-sdk": "^2.15.4"
  }
}
